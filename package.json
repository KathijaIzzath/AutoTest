{
  "name": "autotest",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "npx playwright test",
    "test:blob": "npx playwright test --reporter=blob",
    "test:chromium": "npx playwright test --project=chromium",
    "test:smoke": "npx playwright test tests/001_login_test.spec.ts tests/002_Dashboard_test.spec.ts --project=chromium",
    "test:ui": "npx playwright test --ui",
    "typecheck": "npx tsc -p tsconfig.json --noEmit",
    "report": "npx playwright show-report",
    "report:merge:today": "node scripts/merge-today-report.js",
    "report:show:today": "node scripts/show-today-report.js",
    "cleanup": "node scripts/cleanup-old-artifacts.js",
    "email:test": "node scripts/send-mock-report.js",
    "report:daily": "node scripts/generate-daily-report.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/node": "^25.0.3",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.16.0",
    "nodemailer": "^9.0.3",
    "pg": "^8.17.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@types/pg": "^8.16.0"
  }
}
